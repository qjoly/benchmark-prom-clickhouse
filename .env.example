# Copy to .env and adjust. .env is gitignored (holds the object-storage password).

# ─────────── Object storage credentials (RustFS / Mimir S3) ───────────
# REQUIRED. Do not commit real values. The access key is username-like; the
# secret key is the password and must be set before `make up` / `make k8s-up`.
OBJSTORE_ACCESS_KEY=benchuser
OBJSTORE_SECRET_KEY=change-me-before-running

# ─────────── Image versions ───────────
CH_VERSION=24.8
MIMIR_VERSION=2.13.0
TSBS_REF=master

# ─────────── TSBS dataset parameters ───────────
# cpu-only use case: 10 metrics per host per reading.
USE_CASE=cpu-only
SEED=123

# Number of simulated hosts (= series cardinality).
SCALE=10000

# Interval between two readings.
LOG_INTERVAL=10s

# Simulated duration. points ~= SCALE * 10 * (DURATION / LOG_INTERVAL).
# The duration must exceed the query window (1h for single-groupby), so keep >= 2.
#   presets: smoke -> SCALE=100   DURATION_HOURS=3   (~1M points)
#            big   -> SCALE=10000  DURATION_HOURS=30  (~1.08 Bn points)
DURATION_HOURS=30

# The time range is anchored on "now" by 01_generate.sh (required so Mimir accepts
# the backfill). To pin an exact range, set TS_START / TS_END (RFC3339 UTC).
TS_START=
TS_END=

# ─────────── Load parallelism ───────────
CH_WORKERS=8
CH_BATCH_SIZE=10000
PROM_WORKERS=8
PROM_BATCH_SIZE=10000

# ─────────── Network targets (docker service names) ───────────
CH_HOST=chnode1
CH_PORT=9000
CH_DB=benchmark
MIMIR_WRITE_URL=http://mimir-gw:9009/api/v1/push
MIMIR_QUERY_URL=http://mimir-gw:9009/prometheus

# ─────────── Read queries ───────────
QUERY_TYPE=single-groupby-1-1-1
QUERY_COUNT=1000
